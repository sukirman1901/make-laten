{
  "name": "make-laten",
  "version": "1.0.0",
  "description": "Universal efficiency toolkit for AI coding agents — compress, cache, route, and optimize token usage",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "make-laten": "dist/cli/index.js"
  },
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "coding-agent",
    "token-optimization",
    "compression",
    "caching",
    "claude-code",
    "cursor",
    "codex",
    "efficiency",
    "cli",
    "tool"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/make-laten/make-laten.git"
  },
  "files": [
    "dist",
    "skills"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^13.0.1",
    "commander": "^15.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "tsup": "^8.5.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
